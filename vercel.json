{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/checkin",
      "schedule": "0 16 * * 5",
      "timezone": "Asia/Karachi"
    },
    {
      "path": "/api/cron/summary",
      "schedule": "0 17 * * 5",
      "timezone": "Asia/Karachi"
    }
  ],
  "functions": {
    "api/**/*.js": {
      "maxDuration": 60
    }
  }
}
