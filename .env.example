# Slack App credentials — get these from https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here
SLACK_APP_TOKEN=xapp-your-app-token-here   # Required for Socket Mode

# Channel where the weekly summary is posted (e.g. #weekly-updates)
SUMMARY_CHANNEL_ID=C0000000000

# Comma-separated Slack user IDs to DM (e.g. U0000000001,U0000000002)
# Leave empty to DM all members of SUMMARY_CHANNEL_ID automatically
TEAM_MEMBER_IDS=

# Cron schedule for the check-in (default: 4pm every Friday)
# Format: "minute hour day-of-month month day-of-week"
CHECKIN_CRON=0 16 * * 5

# How many minutes to wait for replies before posting the summary
COLLECTION_WINDOW_MINUTES=60

# Port for the HTTP server (used if not in Socket Mode)
PORT=3000

# ─── Vercel deployment (HTTP mode + Vercel Cron) ─────────────────────────────
# Add the Upstash Redis integration from the Vercel Marketplace.
# It injects UPSTASH_REDIS_REST_URL and UPSTASH_REDIS_REST_TOKEN automatically.

# Protects /api/cron/* routes (Vercel sends this as Authorization: Bearer ...)
CRON_SECRET=your-random-secret-here
